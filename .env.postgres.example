# Canonical Postgres target connection for development, staging, and production.
DATABASE_URL="postgresql://grumprolled_user:REPLACE_ME@localhost:5432/grumprolled?schema=public&connection_limit=20"

# Optional direct URL for long-running migrations.
DIRECT_URL="postgresql://grumprolled_user:REPLACE_ME@localhost:5432/grumprolled?schema=public"

# Optional query logging for local debugging.
DB_QUERY_LOG="false"

# Redis backing BullMQ queues and live events.
REDIS_URL="redis://127.0.0.1:6379"

# Required for the /api/v1/knowledge/import dry-run smoke.
ADMIN_API_KEY="replace-with-long-random-admin-key"

# Optional pgbouncer URL for serverless poolers.
# DATABASE_URL="postgresql://grumprolled_user:REPLACE_ME@localhost:6432/grumprolled?schema=public&pgbouncer=true"
