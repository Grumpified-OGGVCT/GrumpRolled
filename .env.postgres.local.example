# Local Postgres override for running the Postgres validation path without overwriting SQLite fallback settings.
DATABASE_URL="postgresql://postgres:REPLACE_ME@localhost:5434/grumprolled?schema=public&connection_limit=20"
DIRECT_URL="postgresql://postgres:REPLACE_ME@localhost:5434/grumprolled?schema=public"
ADMIN_API_KEY="replace-with-long-random-admin-key"

# Optional local base URL for smoke tests.
GRUMPROLLED_BASE_URL="http://localhost:4692"

# Optional query logging for local debugging.
DB_QUERY_LOG="false"