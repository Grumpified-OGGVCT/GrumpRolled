# ═══════════════════════════════════════════════════════════════════════════
# GrumpRolled Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in real values.
# Never commit .env.local or any file with real secrets.
# ═══════════════════════════════════════════════════════════════════════════

# ── Core ──
NODE_ENV=development
DATABASE_URL="file:./prisma/dev.db"

# ── Domain / Canonical Routing ──
APP_BASE_URL="https://grumprolled.lol"
CANONICAL_HOST="grumprolled.lol"
CANONICAL_HTTPS="true"

# ── Security & Auth ──
# Generate with: openssl rand -hex 32
ADMIN_API_KEY="replace-with-long-random-admin-key"
APP_SESSION_SECRET="replace-with-long-random-session-secret"
NEXTAUTH_SECRET="replace-with-long-random-nextauth-secret"
DID_CHALLENGE_SECRET="replace-with-long-random-did-secret"
NEXTAUTH_URL="http://localhost:4692"

# ── JWS / Agent Card Signing ──
# Optional: set these to persistent Ed25519 keys for production.
# If unset, ephemeral keys are generated each restart (fine for dev).
# Generate with: openssl genpkey -algorithm Ed25519 -out private.pem
# AGENT_CARD_SIGNING_PRIVATE_KEY_PEM=""
# AGENT_CARD_SIGNING_PUBLIC_KEY_PEM=""

# ── CORS / Callbacks / Webhooks ──
CORS_ALLOWED_ORIGINS="https://grumprolled.lol,https://www.grumprolled.lol"
AUTH_ALLOWED_CALLBACK_ORIGINS="https://grumprolled.lol,https://www.grumprolled.lol"
WEBHOOK_BASE_URL="https://grumprolled.lol"

# ── Database (PostgreSQL) ──
# For production: use a real Postgres URL
# DATABASE_URL="postgresql://grumprolled_user:REPLACE_ME@db-host:5432/grumprolled?schema=public&connection_limit=20"
# DIRECT_URL="postgresql://grumprolled_user:REPLACE_ME@db-host:5432/grumprolled?schema=public"
# DB_QUERY_LOG="false"

# ── SQLite Fallback (dev/testing only) ──
# SQLITE_DATABASE_URL="file:./local.db"

# ── LLM Provider Keys ──
# At least one provider is needed for bark engine and answer generation.
OPENAI_API_KEY="sk-..."
ANTHROPIC_API_KEY="sk-ant-..."
DEEPSEEK_API_KEY=""
SILICONFLOW_API_KEY=""
MISTRAL_API_KEY=""
GROQ_API_KEY=""
OPENROUTER_API_KEY=""

# ── Ollama Cloud ──
OLLAMA_API_BASE_URL="https://ollama.com/api"
OLLAMA_API_KEY=""
OLLAMA_API_KEY_1=""
OLLAMA_API_KEY_2=""
OLLAMA_MAX_RPS="5"
OLLAMA_RETRIES_PER_KEY="2"
OLLAMA_CTX_MAX_CHARS="16000"
OLLAMA_CTX_MIN_CHARS="4000"

# ── LLM Multi-Account Keys (optional, up to 8 per provider) ──
# Format: PROVIDER_API_KEYS="key1,key2,..." or PROVIDER_API_KEY_1="key1" ... PROVIDER_API_KEY_8="key8"
# SILICONFLOW_API_KEYS=""
# SILICONFLOW_API_KEY_1="" ... SILICONFLOW_API_KEY_8=""
# DEEPSEEK_API_KEYS=""
# DEEPSEEK_API_KEY_1="" ... DEEPSEEK_API_KEY_8=""
# MISTRAL_API_KEYS=""
# MISTRAL_API_KEY_1="" ... MISTRAL_API_KEY_8=""
# MISTRAL_AI_API_KEYS=""
# MISTRAL_AI_API_KEY_1="" ... MISTRAL_AI_API_KEY_8=""
# GROQ_API_KEYS=""
# GROQ_API_KEY_1="" ... GROQ_API_KEY_8=""
# OPENROUTER_API_KEYS=""
# OPENROUTER_API_KEY_1="" ... OPENROUTER_API_KEY_8=""

# ── TTS (Text-to-Speech) ──
NEXT_PUBLIC_BARK_ENABLED=true
BARK_SPEAKER_DEFAULT=grump
BARK_TTL_HOURS=24
TTS_MIMIC3_ENDPOINT="http://localhost:5002"
TTS_MIMIC3_ENABLED=true
TTS_MIMIC3_TIMEOUT=5000
TTS_COQUI_ENDPOINT="http://localhost:5003"
TTS_COQUI_ENABLED=false
TTS_COQUI_TIMEOUT=8000
TTS_YOURTTS_ENDPOINT="http://localhost:5004"
TTS_YOURTTS_ENABLED=false
TTS_YOURTTS_TIMEOUT=10000
TTS_CACHE_RESPONSES=true
TTS_CACHE_TTL=3600
# YOURTTS_REF_WAV=""  # base64-encoded reference audio for zero-shot voice cloning

# ── Master Agent ──
MASTER_AGENT_ENABLED=false
# MASTER_AGENT_HEALTH_CHECK_INTERVAL=30000
# MASTER_AGENT_COORDINATION_LOG_MAX=1000
# TTS_BROADCAST_TIMEOUT=15000
# TTS_CROSS_POST_TIMEOUT=30000

# ── ChatOverflow Cross-Post Federation ──
CHATOVERFLOW_WRITE_API_KEY=""
CHATOVERFLOW_WRITE_FORUM_ID=""
CHATOVERFLOW_WRITE_API_BASE="https://www.chatoverflow.dev/api"

# ── App Server ──
GRUMPROLLED_PORT=4692
# PORT=4692

# ═══════════════════════════════════════════════════════════════════════════
# Script-specific variables (generally not needed in production .env)
# ═══════════════════════════════════════════════════════════════════════════
# GRUMPROLLED_BASE_URL="http://localhost:4692"
# GRUMPROLLED_API_BASE="http://localhost:4692"
# GR_BASE_URL="http://localhost:4692"
# KNOWLEDGE_AUTHOR_ID=""
# KNOWLEDGE_BATCH_FILE="data/seed-knowledge.json"
# KNOWLEDGE_BATCH_CHUNK=50
# KNOWLEDGE_DRY_RUN=1
# CORPUS_GLOB="data/corpus/*.json"
# CORPUS_CHUNK=100
# CORPUS_DRY_RUN=1
# CORPUS_HANDOFF_DRY_RUN_ONLY=1
# LAB_UPSTREAM_ROOT=""