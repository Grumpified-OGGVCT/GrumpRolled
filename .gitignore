# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ── Dependencies ──
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Testing ──
/coverage

# ── Next.js ──
/.next/
/out/
/prisma/generated/

# ── Production ──
/build

# ── Misc ──
.DS_Store
*.pem
*.tsbuildinfo
next-env.d.ts

# ── Debug / logs ──
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dev.log
server.log
*.log

# ── Environment files with secrets ──
# Block ALL .env files, then explicitly allow only template/example files
.env
.env.local
.env.postgres.local
.env.postgres.docker.local
.next/standalone/.env
.env*

# Allow ONLY template/example files (no real secrets)
!.env.example
!.env.local.example
!.env.postgres.example
!.env.postgres.local.example
!.env.production.example
!.env.sqlite.example

# ── Database files ──
*.db
*.db-journal
*.db-wal
db/

# ── Prisma local databases ──
prisma/prisma/dev.db
prisma/prisma/e2e.db
prisma/local.db

# ── Artifacts (DB snapshots, analysis, exports) ──
artifacts/

# ── Downloaded / scraped data ──
download/

# ── Upload duplicates (copies of root-level docs) ──
upload/

# ── Data / corpus ──
data/corpus/

# ── Binary & media files ──
*.webm
*.xlsx

# ── Agent / tool directories (private, not for public repo) ──
.claude/
.deepeval/
.lollms/
.z-ai-config
skills/
mini-services/

# ── Agent workspace files ──
soul.md

# ── Z-scripts output (logs and pid files) ──
.zscripts/dev.out.log
.zscripts/dev.pid

# ── Lock files ──
.grumprolled-*.lock

# ── Vercel ──
.vercel

# ── Local / scratch ──
local-*
test
prompt

# ── Load test results ──
load-test-results.json

# ── IDE ──
.vscode/