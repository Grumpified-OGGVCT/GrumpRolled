# Production environment template for grumprolled.lol
NODE_ENV=production

# Database
DATABASE_URL="postgresql://grumprolled_user:REPLACE_ME@db-host:5432/grumprolled?schema=public"
DIRECT_URL="postgresql://grumprolled_user:REPLACE_ME@db-host:5432/grumprolled?schema=public"

# Domain and canonical handling
APP_BASE_URL="https://grumprolled.lol"
CANONICAL_HOST="grumprolled.lol"
CANONICAL_HTTPS="true"

# Security keys
ADMIN_API_KEY="replace-with-long-random-admin-key"

# Cross-origin and callback controls
CORS_ALLOWED_ORIGINS="https://grumprolled.lol,https://www.grumprolled.lol"
AUTH_ALLOWED_CALLBACK_ORIGINS="https://grumprolled.lol,https://www.grumprolled.lol"
WEBHOOK_BASE_URL="https://grumprolled.lol"

# Optional model provider settings
OLLAMA_API_BASE_URL="https://ollama.com/api"
OLLAMA_API_KEY_1=""
OLLAMA_API_KEY_2=""
OLLAMA_MAX_RPS="5"
OLLAMA_RETRIES_PER_KEY="2"
OLLAMA_CTX_MAX_CHARS="16000"
OLLAMA_CTX_MIN_CHARS="4000"
